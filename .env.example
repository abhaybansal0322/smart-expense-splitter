# Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here" # Generate with `openssl rand -base64 32`

# Spotify Integration (Optional)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Docker Compose local database defaults
# These are only used by docker-compose.yml when DATABASE_URL is not provided.
POSTGRES_DB="smart_expense_splitter"
POSTGRES_USER="smart_expense"
POSTGRES_PASSWORD="smart_expense_password"
POSTGRES_PORT="5432"
APP_PORT="3000"
